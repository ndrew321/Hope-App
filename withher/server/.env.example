# ─────────────────────────────────────────────
# with/her Server — Environment Variables
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# ─── DATABASE ────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/withher_db?schema=public"

# ─── SERVER ──────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed browser origins
ALLOWED_ORIGINS=http://localhost:8081
# Legacy single-origin var still supported by code
CORS_ORIGIN=http://localhost:8081

# ─── FIREBASE (Service Account) ──────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ─── REDIS (for Bull job queues) ─────────────
REDIS_URL=redis://localhost:6379

# ─── EMAIL (SMTP) ────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@withher.app

# ─── BACKGROUND CHECKS (Checkr) ──────────────
CHECKR_API_KEY=your-checkr-api-key
CHECKR_BASE_URL=https://api.checkr.com/v1
CHECKR_WEBHOOK_SECRET=your-checkr-webhook-secret

# ─── MATCHING MICROSERVICE ───────────────────
MATCHING_SERVICE_URL=http://localhost:8000

# ─── JWT (fallback / internal tokens) ────────
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-chars

# ─── MODERATION ──────────────────────────────
MODERATION_EMAIL=safety@withher.app
