// ─────────────────────────────────────────────────────────
// with/her — Full Prisma Database Schema
// PostgreSQL + pgvector extension required
// ─────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── ENUMS ───────────────────────────────────────────────

enum CareerLevel {
  YOUTH
  HIGH_SCHOOL
  COLLEGE
  PROFESSIONAL
  ALUM
}

enum MentorshipRole {
  MENTOR
  MENTEE
  BOTH
}

enum CommunicationPreference {
  SYNC
  ASYNC
  BOTH
}

enum MatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  EXPIRED
  REJECTED
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  MISSED
  RESCHEDULED
  CANCELLED
}

enum SessionType {
  SYNC_CALL
  ASYNC_MESSAGE
  GROUP
  EVENT
}

enum MessageType {
  TEXT
  VOICE
  IMAGE
  FILE
  SYSTEM
}

enum PostStatus {
  PUBLISHED
  PENDING_REVIEW
  REJECTED
}

enum EventType {
  WORKSHOP
  NETWORKING
  SUMMIT
  LOCAL_MEETUP
  CLINIC
}

enum EventStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  REGISTERED
  ATTENDED
  CANCELLED
}

enum ResourceType {
  ARTICLE
  VIDEO
  GUIDE
  BOOK
  COURSE
  TOOL
}

enum VerificationType {
  EMAIL
  PHONE
  IDENTITY
  BACKGROUND_CHECK
  PARENTAL_CONSENT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

// ─── MODELS ──────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  /// Firebase UID — used to verify Auth tokens
  firebaseUid        String    @unique
  email              String    @unique
  phone              String?   @unique
  firstName          String
  lastName           String
  dateOfBirth        DateTime?
  gender             String?
  location           String?
  profilePhotoUrl    String?
  bio                String?   @db.Text
  isVerified         Boolean   @default(false)
  verificationStatus String    @default("UNVERIFIED")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime? // soft delete

  // Relations
  profile            UserProfile?
  preferences        UserPreferences?
  matchesAsMentor    Match[]                 @relation("MentorMatches")
  matchesAsMentee    Match[]                 @relation("MenteeMatches")
  sentMessages       Message[]               @relation("SentMessages")
  receivedMessages   Message[]               @relation("ReceivedMessages")
  forumPosts         ForumPost[]
  forumComments      ForumComment[]
  organizedEvents    Event[]
  eventRegistrations EventRegistration[]
  userBadges         UserBadge[]
  verifications      Verification[]
  parentalConsent    ParentalConsent?        @relation("ChildConsent")
  reportsFiled       Report[]                @relation("ReportsFiled")
  reportsReceived    Report[]                @relation("ReportsReceived")
  blocksInitiated    Block[]                 @relation("BlocksInitiated")
  blocksReceived     Block[]                 @relation("BlocksReceived")
  savedResources     SavedResource[]
  notificationPrefs  NotificationPreference?
  pushTokens         PushToken[]
  sessions           LoginSession[]

  @@index([email])
  @@index([firebaseUid])
  @@index([deletedAt])
}

model UserProfile {
  id                       String                      @id @default(cuid())
  userId                   String                      @unique
  currentLevel             CareerLevel                 @default(YOUTH)
  positions                String[]                    @default([])
  yearsExperience          Int                         @default(0)
  clubsTeams               String[]                    @default([])
  specializedPrograms      String[]                    @default([])
  mentorshipRole           MentorshipRole              @default(BOTH)
  mentorshipGoals          String?                     @db.Text
  careerGoals              String?                     @db.Text
  communicationStyle       String?
  personalityTraits        String[]                    @default([])
  bipocIdentification      Boolean                     @default(false)
  lgbtqIdentification      Boolean                     @default(false)
  interestsOutsideSoccer   String[]                    @default([])
  profileCompletenessScore Int                         @default(0)
  /// Sentence-transformer embedding of mentorshipGoals (384-dim for all-MiniLM-L6-v2)
  goalsEmbedding           Unsupported("vector(384)")?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentLevel])
}

model UserPreferences {
  id                       String                  @id @default(cuid())
  userId                   String                  @unique
  preferredMentorLevels    CareerLevel[]           @default([])
  preferredMenteeLevels    CareerLevel[]           @default([])
  geographicPreference     String?
  maxDistanceKm            Int                     @default(50)
  availabilityHoursPerWeek Int                     @default(2)
  timezone                 String                  @default("UTC")
  communicationPreference  CommunicationPreference @default(BOTH)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Match {
  id               String      @id @default(cuid())
  mentorId         String
  menteeId         String
  matchScore       Float       @default(0.0)
  status           MatchStatus @default(PENDING)
  programStartDate DateTime?
  programEndDate   DateTime?
  matchedVia       String      @default("algorithm")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  mentor             User                @relation("MentorMatches", fields: [mentorId], references: [id])
  mentee             User                @relation("MenteeMatches", fields: [menteeId], references: [id])
  mentorshipPrograms MentorshipProgram[]
  messages           Message[]
  swipes             Swipe[]

  @@unique([mentorId, menteeId])
  @@index([mentorId])
  @@index([menteeId])
  @@index([status])
}

/// Records individual swipe decisions before a mutual match is confirmed
model Swipe {
  id        String   @id @default(cuid())
  swiperId  String
  targetId  String
  direction String // "left" | "right"
  matchId   String?
  createdAt DateTime @default(now())

  match Match? @relation(fields: [matchId], references: [id])

  @@unique([swiperId, targetId])
  @@index([swiperId])
  @@index([targetId])
}

model MentorshipProgram {
  id                   String        @id @default(cuid())
  matchId              String
  programNumber        Int           @default(1)
  status               ProgramStatus @default(ACTIVE)
  startDate            DateTime      @default(now())
  endDate              DateTime?
  menteeInitialGoal    String?       @db.Text
  menteeReflection     String?       @db.Text
  mentorFeedback       String?       @db.Text
  ratingByMentee       Int? // 1–5
  ratingByMentor       Int? // 1–5
  completionPercentage Float         @default(0.0)

  match    Match     @relation(fields: [matchId], references: [id])
  sessions Session[]

  @@index([matchId])
  @@index([status])
}

model Session {
  id                  String        @id @default(cuid())
  mentorshipProgramId String
  sessionNumber       Int
  scheduledDate       DateTime?
  scheduledTime       String?
  actualDate          DateTime?
  durationMinutes     Int?
  status              SessionStatus @default(SCHEDULED)
  sessionType         SessionType   @default(SYNC_CALL)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  mentorshipProgram MentorshipProgram @relation(fields: [mentorshipProgramId], references: [id])
  notes             SessionNotes?

  @@index([mentorshipProgramId])
  @@index([status])
  @@index([scheduledDate])
}

model SessionNotes {
  id                   String   @id @default(cuid())
  sessionId            String   @unique
  mentorNotes          String?  @db.Text
  menteeReflection     String?  @db.Text
  topicsDiscussed      String[] @default([])
  actionItemsForMentee String[] @default([])
  actionItemsForMentor String[] @default([])
  keyTakeaways         String[] @default([])
  resourcesShared      String[] @default([])
  nextSessionAgenda    String?  @db.Text
  menteeSelfRating     Int? // 1–5
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model Message {
  id          String      @id @default(cuid())
  senderId    String
  recipientId String
  matchId     String
  messageType MessageType @default(TEXT)
  content     String?     @db.Text
  mediaUrl    String?
  isRead      Boolean     @default(false)
  isFlagged   Boolean     @default(false)
  flagReason  String?
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?

  sender    User  @relation("SentMessages", fields: [senderId], references: [id])
  recipient User  @relation("ReceivedMessages", fields: [recipientId], references: [id])
  match     Match @relation(fields: [matchId], references: [id])

  @@index([matchId])
  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
  @@index([deletedAt])
}

model ForumPost {
  id         String     @id @default(cuid())
  authorId   String
  category   String
  topic      String
  title      String
  content    String     @db.Text
  tags       String[]   @default([])
  upvotes    Int        @default(0)
  downvotes  Int        @default(0)
  replyCount Int        @default(0)
  isPinned   Boolean    @default(false)
  status     PostStatus @default(PUBLISHED)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  author   User           @relation(fields: [authorId], references: [id])
  comments ForumComment[]

  @@index([authorId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

model ForumComment {
  id              String    @id @default(cuid())
  postId          String
  authorId        String
  content         String    @db.Text
  upvotes         Int       @default(0)
  isMarkedHelpful Boolean   @default(false)
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  post   ForumPost @relation(fields: [postId], references: [id])
  author User      @relation(fields: [authorId], references: [id])

  @@index([postId])
  @@index([authorId])
}

model Event {
  id                   String        @id @default(cuid())
  organizerId          String
  eventType            EventType
  title                String
  description          String        @db.Text
  startDatetime        DateTime
  endDatetime          DateTime
  locationOrLink       String?
  maxAttendees         Int?
  attendeeCount        Int           @default(0)
  levelTargeting       CareerLevel[] @default([])
  registrationRequired Boolean       @default(false)
  status               EventStatus   @default(PLANNING)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  organizer     User                @relation(fields: [organizerId], references: [id])
  registrations EventRegistration[]

  @@index([organizerId])
  @@index([status])
  @@index([startDatetime])
}

model EventRegistration {
  id             String             @id @default(cuid())
  eventId        String
  userId         String
  status         RegistrationStatus @default(REGISTERED)
  registeredAt   DateTime           @default(now())
  attendedAt     DateTime?
  feedbackRating Int?
  feedbackText   String?            @db.Text

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model Resource {
  id              String        @id @default(cuid())
  type            ResourceType
  title           String
  description     String?       @db.Text
  authorOrCurator String?
  urlOrFilePath   String
  category        String[]      @default([])
  levelTargeting  CareerLevel[] @default([])
  topicTags       String[]      @default([])
  approvedByAdmin Boolean       @default(false)
  viewCount       Int           @default(0)
  saveCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  saves SavedResource[]

  @@index([type])
  @@index([approvedByAdmin])
}

model SavedResource {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  savedAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([userId, resourceId])
  @@index([userId])
}

model Badge {
  id           String  @id @default(cuid())
  badgeType    String  @unique
  name         String
  description  String  @db.Text
  iconUrl      String?
  criteriaJson Json

  userBadges UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  earnedDate DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

model Verification {
  id               String             @id @default(cuid())
  userId           String
  verificationType VerificationType
  status           VerificationStatus @default(PENDING)
  documentUrls     String[]           @default([])
  verifiedDate     DateTime?
  expirationDate   DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, verificationType])
  @@index([userId])
  @@index([status])
}

model ParentalConsent {
  id           String    @id @default(cuid())
  childUserId  String    @unique
  parentEmail  String
  parentName   String
  consentGiven Boolean   @default(false)
  signatureUrl String?
  signedDate   DateTime?
  termsVersion String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  childUser User @relation("ChildConsent", fields: [childUserId], references: [id])

  @@index([childUserId])
  @@index([parentEmail])
}

model Report {
  id               String        @id @default(cuid())
  reportedByUserId String
  reportedUserId   String
  reportType       String
  description      String        @db.Text
  evidenceUrls     String[]      @default([])
  severityLevel    SeverityLevel @default(LOW)
  status           ReportStatus  @default(PENDING)
  actionTaken      String?
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  reportedByUser User @relation("ReportsFiled", fields: [reportedByUserId], references: [id])
  reportedUser   User @relation("ReportsReceived", fields: [reportedUserId], references: [id])

  @@index([reportedUserId])
  @@index([status])
  @@index([severityLevel])
}

model Block {
  id            String   @id @default(cuid())
  blockerUserId String
  blockedUserId String
  blockDate     DateTime @default(now())

  blocker User @relation("BlocksInitiated", fields: [blockerUserId], references: [id])
  blocked User @relation("BlocksReceived", fields: [blockedUserId], references: [id])

  @@unique([blockerUserId, blockedUserId])
  @@index([blockerUserId])
  @@index([blockedUserId])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  newMatch              Boolean  @default(true)
  newMessage            Boolean  @default(true)
  sessionReminder       Boolean  @default(true)
  sessionNotes          Boolean  @default(true)
  communityPost         Boolean  @default(true)
  badgeEarned           Boolean  @default(true)
  programEndingReminder Boolean  @default(true)
  weeklyDigest          Boolean  @default(true)
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String // "ios" | "android"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

/// Tracks active Firebase auth sessions for logout propagation
model LoginSession {
  id        String   @id @default(cuid())
  userId    String
  sessionId String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}
